      {"q": "\u053b\u0576\u0579\u057a\u0565\u057d \u0567 \u0561\u0577\u056d\u0561\u057f\u0578\u0582\u0574 \u0585\u0586\u056c\u0561\u0575\u0576 \u057e\u0565\u0580\u056c\u0578\u0582\u056e\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0568?", "a": "\u0532\u0578\u056c\u0578\u0580 \u057e\u0565\u0580\u056c\u0578\u0582\u056e\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580\u0568 \u056f\u0561\u057f\u0561\u0580\u057e\u0578\u0582\u0574 \u0565\u0576 \u057f\u0565\u0572\u0561\u056f\u0561\u0576 \u2014 CSV, OFX, QIF, MT940 \u0587 CAMT \u057e\u0565\u0580\u056c\u0578\u0582\u056e\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0568 \u0566\u0580\u0578 \u0581\u0561\u0576\u0581\u0561\u0575\u056b\u0576 \u056f\u0561\u0576\u0579 \u0567 \u057a\u0561\u0570\u0561\u0576\u057b\u0578\u0582\u0574\u0589 PDF OCR-\u0568 \u0585\u0563\u057f\u0561\u0563\u0578\u0580\u056e\u0578\u0582\u0574 \u0567 Tesseract.js, \u0578\u0580\u0568 \u0561\u0577\u056d\u0561\u057f\u0578\u0582\u0574 \u0567 \u0562\u0580\u0561\u0578\u0582\u0566\u0565\u0580\u0578\u0582\u0574 \u056f\u0561\u0574 Node.js-\u0578\u0582\u0574\u0589 \u054f\u057e\u0575\u0561\u056c\u0576\u0565\u0580\u0568 \u0565\u0580\u0562\u0565\u0584 \u0579\u0565\u0576 \u056c\u0584\u0576\u0578\u0582\u0574 \u0571\u0565\u0580 \u0565\u0576\u0569\u0561\u056f\u0561\u057c\u0578\u0582\u0581\u057e\u0561\u056e\u0584\u0568\u0589"},
      {"q": "\u053f\u0561\u0580\u0578\u0572 \u0565\u0574 \u0561\u057e\u0565\u056c\u0561\u0581\u0576\u0565\u056c \u056b\u0574 \u0562\u0561\u0576\u056f\u0568?", "a": "\u0531\u0575\u0578\u0589 \u0555\u0563\u057f\u0561\u0563\u0578\u0580\u056e\u0565\u0584 registerBank() \u0563\u0578\u0580\u056e\u0561\u0580\u056f\u0574\u0561\u0576 \u056a\u0561\u0574\u0561\u0576\u0561\u056f, \u0562\u0565\u057c\u0576\u0565\u0584 JSON \u056f\u0561\u0580\u0563\u0561\u057e\u0578\u0580\u0574\u0561\u0576 \u0586\u0561\u0575\u056c\u0565\u0580 \u056f\u0561\u0574 \u0585\u0563\u057f\u0561\u0563\u0578\u0580\u056e\u0565\u0584 CLI config suggest \u0570\u0580\u0561\u0574\u0561\u0576\u0568\u055d \u0576\u0574\u0578\u0582\u0577\u056b CSV-\u056b\u0581 \u057d\u0575\u0578\u0582\u0576\u0576\u0565\u0580\u056b \u0561\u057e\u057f\u0578\u0574\u0561\u057f \u0570\u0561\u0575\u057f\u0576\u0561\u0562\u0565\u0580\u0574\u0561\u0576 \u0570\u0561\u0574\u0561\u0580\u0589"},
      {"q": "\u053b\u057d\u056f AI \u0570\u0576\u0561\u0580\u0561\u057e\u0578\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580\u056b\u0576?", "a": "AI-\u0576 100% \u0568\u0576\u057f\u0580\u0578\u057e\u056b \u0567\u0589 \u0532\u0578\u056c\u0578\u0580 \u057e\u0565\u0580\u056c\u0578\u0582\u056e\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580\u0568 \u0561\u0577\u056d\u0561\u057f\u0578\u0582\u0574 \u0565\u0576 \u0561\u057c\u0561\u0576\u0581 \u0564\u0580\u0561\u0589 \u0535\u0569\u0565 \u0581\u0561\u0576\u056f\u0561\u0576\u0578\u0582\u0574 \u0565\u0584 \u056d\u0565\u056c\u0561\u0581\u056b \u056f\u0580\u056f\u0576\u0578\u0580\u056b\u0576\u0561\u056f\u0576\u0565\u0580\u056b \u0570\u0561\u0575\u057f\u0576\u0561\u0562\u0565\u0580\u0578\u0582\u0574 \u056f\u0561\u0574 \u0561\u057c\u0587\u057f\u0580\u0561\u056f\u0561\u0576\u056b \u0570\u0561\u0580\u057d\u057f\u0561\u0581\u0578\u0582\u0574, \u0562\u0565\u0580\u0565\u0584 \u057d\u0565\u0583\u0561\u056f\u0561\u0576 API \u0562\u0561\u0576\u0561\u056c\u056b\u0576 (OpenAI, Anthropic \u056f\u0561\u0574 \u0581\u0561\u0576\u056f\u0561\u0581\u0561\u056e LLM) AIProvider \u056b\u0576\u057f\u0565\u0580\u0586\u0565\u0575\u057d\u056b \u0574\u056b\u057b\u0578\u0581\u0578\u057e\u0589"},
      {"q": "\u053f\u0561 \u0561\u0576\u057e\u0573\u0561\u0580 \u0583\u0578\u0580\u0571\u0561\u0577\u0580\u057b\u0561\u0576?", "a": "\u0540\u056b\u0574\u0576\u0561\u056f\u0561\u0576 \u057e\u0565\u0580\u056c\u0578\u0582\u056e\u056b\u0579\u0576\u0565\u0580\u0568 \u0570\u0561\u057d\u0561\u0576\u0565\u056c\u056b \u0565\u0576 \u0578\u0580\u057a\u0565\u057d \u0562\u0561\u0581 \u056f\u0578\u0564\u056b npm \u0583\u0561\u0569\u0565\u0569\u0589 Pro \u057f\u0561\u0580\u0562\u0565\u0580\u0561\u056f\u0568 ($79) \u0576\u0565\u0580\u0561\u057c\u0578\u0582\u0574 \u0567 PDF OCR, CAMT/MT940 \u0561\u057b\u0561\u056f\u0581\u0578\u0582\u0569\u0575\u0578\u0582\u0576, CLI \u0563\u0578\u0580\u056e\u056b\u0584, AI \u056b\u0576\u057f\u0565\u0580\u0586\u0565\u0575\u057d \u0587 \u0561\u057c\u0561\u057b\u0576\u0561\u0570\u0565\u0580\u0569 \u0562\u0561\u0576\u056f\u0561\u0575\u056b\u0576 \u056f\u0561\u0580\u0563\u0561\u057e\u0578\u0580\u0578\u0582\u0574\u0576\u0565\u0580\u0589"}
